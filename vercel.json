{
  "version": 2,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/", "destination": "/widget/index.html" },
    { "source": "/widget/:path*", "destination": "/widget/:path*" }
  ],
  "functions": {
    "api/index.py": {
      "maxDuration": 60
    }
  }
}
